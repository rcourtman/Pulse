{
  "$schema": "./mobile_compatibility_manifest.schema.json",
  "schema_version": 1,
  "contract_version": 1,
  "mobile_role": "Away-from-desk decision surface for the same Pulse runtime: attention, approvals, reconnect, instance switching, contextual Assistant handoff, and safe recovery.",
  "surface_classes": [
    {
      "id": "mobile-required",
      "description": "The mobile client must consume the capability directly and compatibility is part of feature completion."
    },
    {
      "id": "mobile-handoff-only",
      "description": "Mobile must preserve context and provide a safe handoff to the owning desktop surface."
    },
    {
      "id": "desktop-only",
      "description": "The capability is intentionally desktop-only and must not change a mobile-owned transport or outcome."
    }
  ],
  "pairing": {
    "schema": "pulse-mobile-onboarding-v1",
    "scheme": "pulse",
    "host": "connect",
    "required_fields": [
      "auth_token",
      "instance_id",
      "relay_url"
    ],
    "optional_fields": [
      "identity_fingerprint",
      "identity_public_key",
      "instance_url",
      "name"
    ]
  },
  "push": {
    "required_fields": [
      "action_id",
      "action_type",
      "body",
      "instance_id",
      "priority",
      "title",
      "type"
    ],
    "types": [
      { "value": "patrol_finding", "go_symbol": "PushTypePatrolFinding" },
      { "value": "patrol_critical", "go_symbol": "PushTypePatrolCritical" },
      { "value": "approval_request", "go_symbol": "PushTypeApprovalRequest" },
      { "value": "fix_completed", "go_symbol": "PushTypeFixCompleted" }
    ],
    "priorities": [
      { "value": "normal", "go_symbol": "PushPriorityNormal" },
      { "value": "high", "go_symbol": "PushPriorityHigh" }
    ],
    "actions": [
      {
        "value": "view_finding",
        "go_symbol": "PushActionViewFinding",
        "destination": "finding-detail",
        "lifecycle": "current"
      },
      {
        "value": "view_alert",
        "go_symbol": "PushActionViewAlert",
        "destination": "finding-detail",
        "lifecycle": "compatibility"
      },
      {
        "value": "approve_fix",
        "go_symbol": "PushActionApproveFix",
        "destination": "approval-detail",
        "lifecycle": "compatibility"
      },
      {
        "value": "decide_action",
        "go_symbol": "PushActionDecideAction",
        "destination": "approval-detail",
        "lifecycle": "current"
      },
      {
        "value": "view_fix_result",
        "go_symbol": "PushActionViewFixResult",
        "destination": "finding-detail",
        "lifecycle": "current"
      }
    ]
  },
  "routes": [
