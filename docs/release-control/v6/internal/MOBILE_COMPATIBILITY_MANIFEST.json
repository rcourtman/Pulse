      "id": "onboarding-qr",
      "go_symbol": "relayMobileRouteOnboardingQR",
      "method": "GET",
      "path": "/api/onboarding/qr",
      "required_scope": "settings:read",
      "lifecycle": "current",
      "mobile_impact": "mobile-required",
      "implementation_paths": ["internal/api/onboarding_handlers.go"],
      "request_fields": [],
      "response_fields": [
        { "path": "schema", "type": "string" },
        { "path": "instance_id", "type": "string", "required": false },
        { "path": "relay.url", "type": "string" },
        { "path": "auth_token", "type": "string" },
        { "path": "deep_link", "type": "string" },
        { "path": "diagnostics", "type": "array" }
      ]
    },
    {
